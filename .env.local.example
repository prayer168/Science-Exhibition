# 複製此檔為 .env.local 並填入實際值

# 用 `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"` 產生
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google Cloud Console → API 與服務 → 憑證 → 建立 OAuth 用戶端 ID（網頁應用程式）
# 已授權的重新導向 URI： http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 允許登入後台的 Google 帳號（多個以逗號分隔）
ALLOWED_EMAILS="you@gmail.com"

# ── 部署到 Railway 時，於專案的 Variables 設定以下值 ──
# AUTH_URL         = https://<你的-railway-網域>           （正式網址）
# AUTH_SECRET      = （同上產生的隨機字串）
# AUTH_GOOGLE_ID   = （Google OAuth 用戶端 ID）
# AUTH_GOOGLE_SECRET = （Google OAuth 用戶端密鑰）
# ALLOWED_EMAILS   = prayer168@gmail.com
# DATA_DIR         = /data                                （指向掛載的 Volume）
# 並在 Google 憑證的重新導向 URI 加入： https://<你的-railway-網域>/api/auth/callback/google
